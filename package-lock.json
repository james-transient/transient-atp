{
  "name": "transient-atp",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "transient-atp",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@atp/conformance-cli": {
      "resolved": "packages/conformance-cli",
      "link": true
    },
    "node_modules/@atp/release-guard": {
      "resolved": "packages/release-guard",
      "link": true
    },
    "node_modules/@atp/spec": {
      "resolved": "packages/spec",
      "link": true
    },
    "packages/conformance-cli": {
      "name": "@atp/conformance-cli",
      "version": "1.0.1",
      "license": "Apache-2.0",
      "dependencies": {
        "@atp/spec": "1.0.0"
      },
      "bin": {
        "atp-conformance": "src/cli.mjs"
      }
    },
    "packages/release-guard": {
      "name": "@atp/release-guard",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "dependencies": {
        "@atp/spec": "1.0.0"
      },
      "bin": {
        "atp-release-guard": "src/cli.mjs"
      }
    },
    "packages/spec": {
      "name": "@atp/spec",
      "version": "1.0.0",
      "license": "Apache-2.0"
    }
  }
}
