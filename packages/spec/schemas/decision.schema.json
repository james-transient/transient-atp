{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.transientintelligence.com/atp/decision.schema.json",
  "title": "ATP Decision",
  "type": "object",
  "required": [
    "decision_id",
    "intent_id",
    "outcome",
    "reason_code",
    "decided_at"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^TD-\\d+$"
    },
    "intent_id": {
      "type": "string",
      "pattern": "^TI-\\d+$"
    },
    "outcome": {
      "type": "string",
      "enum": ["allow", "approve", "deny"]
    },
    "reason_code": {
      "type": "string",
      "minLength": 1
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
